{
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "python3 .claude/hooks/clone_icl_experiments.py",
                        "timeout": 120,
                        "statusMessage": "Cloning vendored icl_experiments into vendor/..."
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "command -v uv >/dev/null 2>&1 && uv sync 2>/dev/null || true",
                        "timeout": 120,
                        "statusMessage": "Syncing Python dependencies with uv..."
                    }
                ]
            }
        ]
    }
}

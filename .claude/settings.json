{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v uv >/dev/null 2>&1 && uv sync 2>/dev/null || true",
            "timeout": 120,
            "statusMessage": "Syncing Python dependencies with uv..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-code-vendored-refs@vendored-refs": true
  },
  "extraKnownMarketplaces": {
    "vendored-refs": {
      "source": {
        "source": "git",
        "url": "https://gitlab.com/charlesbaynham/claude-code-vendored_refs.git"
      }
    }
  }
}
